  "info": {
    "_postman_id": "7934a4e1-4608-43cf-b692-329feffa010b",
    "name": "Telstra Mobile Number Verification API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Telstra Mobile Number Verification (formerly Mobile Origin Verification)\nprovides silent, friction-free verification that the device making a\nrequest is on the Telstra mobile data network, and that the SIM\nassociated with the data session matches the MSISDN supplied by the\ncustomer. Designed to replace SMS OTP for in-app sign-in, account\nrecovery, and fraud checks on the Telstra consumer mobile network.\n\n\nContact Support:\n Name: Telstra Developer Support",
      "type": "text/plain"
    }
  }
